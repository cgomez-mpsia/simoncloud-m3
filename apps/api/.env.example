# SimonCloud API — variables de entorno (NUNCA commitear el .env real)

# Auth — JWT RS256 (PEM). En producción vienen de Vault / Docker Secrets.
# Generar par de claves de desarrollo:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
AUTH_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
AUTH_JWT_TTL_SECONDS=28800
AUTH_COOKIE_NAME=simoncloud_token

PORT=3000
