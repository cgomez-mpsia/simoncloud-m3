---
title: "Modelo de Datos — SimonCloud (Entidades principales)"
---
erDiagram
    USUARIO ||--o{ ARCHIVO : "sube"
    USUARIO ||--o{ SIMONDROP : "crea (Docente)"
    USUARIO ||--|| QUOTA : "tiene"
    SIMONDROP ||--o{ ARCHIVO : "contiene"
    SIMONDROP ||--o{ SUBMISSION : "recibe"
    SIMONDROP ||--o{ TOKEN_EXTERNO : "genera (FSD-UC-011)"
    SUBMISSION }o--|| ARCHIVO : "referencia"
    ARCHIVO ||--o{ VERSION : "tiene versiones"
    USUARIO ||--o{ AUDIT_LOG : "genera"

    USUARIO {
        uuid id PK
        string email "dominio @umss.edu.bo"
        string nombre_completo
        enum rol "Estudiante|Docente|Administrativo|Admin"
        string websiss_sub "ID externo WebSISS"
        datetime created_at
    }

    ARCHIVO {
        uuid id PK
        string nombre
        bigint tamano_bytes
        string mime_type
        string hash_sha256 "64 chars hex"
        boolean solo_lectura
        string s3_key
        uuid simondrop_id FK
        uuid propietario_id FK
        datetime subido_en
        datetime deleted_at "null si activo"
    }

    SIMONDROP {
        uuid id PK
        string nombre
        string descripcion
        datetime cierre_en
        boolean activo
        uuid docente_id FK
        string lms_assignment_id "null si creado sin LMS"
        string lms_course_id "null si creado sin LMS"
    }

    TOKEN_EXTERNO {
        uuid id PK
        uuid simondrop_id FK
        uuid archivo_id FK
        string hmac_signature "HMAC-SHA256 hex 64 chars"
        int ttl_horas "max 72"
        datetime expires_at
        boolean revocado
        datetime created_at
    }

    QUOTA {
        uuid id PK
        uuid usuario_id FK
        int quota_used_mb
        int quota_limit_mb "15360 free | 51200 pro"
        enum plan "FREEMIUM|PRO"
        datetime pro_activado_en
    }

    AUDIT_LOG {
        uuid log_id PK
        uuid user_id FK
        string accion
        string ip_address
        jsonb metadata
        datetime timestamp
    }
