---
title: "C4 Nivel 2 — Contenedores SimonCloud"
---
C4Container
title Diagrama de Contenedores (C4 Nivel 2) — SimonCloud

Person(usuario, "Usuario UMSS", "Estudiante, Docente, Administrativo o Admin")
Person_Ext(externo, "Usuario Externo", "Evaluador sin cuenta UMSS — accede con token temporal HMAC-SHA256")

Container(spa, "SPA React", "React 18 + TypeScript + Vite", "Interfaz web unificada por rol")
Container(gateway, "API Gateway", "NestJS 10", "Único punto de entrada: JWT, routing, rate-limit")
Container(auth, "auth-service", "NestJS + Passport OAuth2", "SSO WebSISS, emisión JWT, RBAC, tokens externos HMAC-SHA256")
Container(files, "file-service", "NestJS + MinIO SDK (S3-compatible)", "Subida chunked, SHA-256 incremental, presigned URLs")
Container(drops, "simondrop-service", "NestJS", "Buzones de entrega, cierres automáticos, comprobantes, deep links LTI")
Container(quota, "quota-service", "NestJS + Saga + Circuit Breaker", "Cuotas 15GB/50GB, saga de pago QR Simple, Circuit Breaker")
Container(expedientes, "expedientes-service", "NestJS", "Aprobación/rechazo de documentos, control de versiones, audit trail")
Container(notif, "notification-service", "NestJS + web-push", "Emails institucionales, push browser, Dead Letter Queue")
Container(admin_svc, "admin-service", "NestJS + CQRS Read Model", "Panel admin, métricas globales, audit log exportable PDF")

ContainerDb(pg, "PostgreSQL 16", "on-premise (primary + hot-standby)", "Usuarios, archivos, buzones, cuotas, expedientes, audit_log, outbox_events")
ContainerDb(redis, "Redis Cluster 7", "on-premise (3 nodos, Consistent Hashing)", "Sesiones upload chunked; cache quota-service Circuit Breaker")
ContainerDb(s3_obj, "MinIO Object Storage", "on-premise + Object Lock WORM", "Archivos binarios; WORM automático post-cierre SimonDrop")
ContainerDb(rabbit, "RabbitMQ + DLQ", "on-premise", "Exchanges: simondrop, pagos, expedientes, auth; Dead Letter Queue")

System_Ext(websiss, "WebSISS SSO", "IdP institucional UMSS — OAuth2/SAML")
System_Ext(lms, "LMS (Moodle / Classroom)", "Integración LTI 1.3 — deep links y notificaciones AGS")
System_Ext(qrsimple, "QR Simple Bolivia", "Pasarela de pago nacional — webhook HMAC-SHA256")

Rel(usuario, spa, "Accede", "HTTPS")
Rel(externo, gateway, "GET /external/drops/:id/archivos?token=<hmac>", "HTTPS (sin JWT)")
Rel(spa, gateway, "API Calls", "HTTPS REST")
Rel(gateway, auth, "Valida JWT / genera token externo", "gRPC")
Rel(gateway, files, "/files/*", "REST")
Rel(gateway, drops, "/drops/*", "REST")
Rel(gateway, quota, "/quota/*", "REST")
Rel(gateway, expedientes, "/expedientes/*", "REST")
Rel(gateway, admin_svc, "/admin/*", "REST")
Rel(files, pg, "CRUD archivos + INSERT outbox_events (Prisma $transaction)", "SQL")
Rel(files, redis, "Sesiones upload chunked", "Redis Protocol")
Rel(files, s3_obj, "PUT/GET objetos binarios", "S3 API (MinIO)")
Rel(files, rabbit, "Publica ArchivoSubidoIntegrationEvent (Outbox Pattern)", "AMQP")
Rel(drops, rabbit, "Publica SimonDropCreadoIntegrationEvent, SimonDropCerradoIntegrationEvent", "AMQP")
Rel(quota, rabbit, "Publica QuotaUpgradeSolicitadoEvent, PagoConfirmadoIntegrationEvent", "AMQP")
Rel(expedientes, rabbit, "Publica DocumentoAprobado/RechazadoIntegrationEvent", "AMQP")
Rel(notif, rabbit, "Consume todos los exchanges (fanout interno)", "AMQP")
Rel(admin_svc, pg, "Read Model CQRS (replica)", "SQL")
Rel(admin_svc, rabbit, "Consume eventos audit (UsuarioAutenticado, TokenExterno, QuotaActualizada)", "AMQP")
Rel(auth, websiss, "Autentica usuarios institucionales", "OAuth2/SAML")
Rel(drops, lms, "Crea deep links LTI, notifica entregas (LTI AGS)", "LTI 1.3 / HTTPS")
Rel(quota, qrsimple, "Recibe webhook de pago confirmado (HMAC-SHA256)", "HTTPS")
