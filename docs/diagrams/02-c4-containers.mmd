---
title: "C4 Nivel 2 — Contenedores SimonCloud"
---
C4Container
title Diagrama de Contenedores (C4 Nivel 2) — SimonCloud

Person(usuario, "Usuario UMSS", "Cualquier usuario institucional")

Container(spa, "SPA React", "React 18 + TypeScript + Vite", "Interfaz web unificada por rol")
Container(gateway, "API Gateway", "NestJS 10", "Único punto de entrada: JWT, routing, rate-limit")
Container(auth, "auth-service", "NestJS + Passport OAuth2", "SSO WebSISS, emisión JWT, RBAC")
Container(files, "file-service", "NestJS + MinIO SDK (S3-compatible)", "Subida chunked, SHA-256, presigned URLs")
Container(drops, "simondrop-service", "NestJS", "Buzones de entrega, cierres automáticos, comprobantes")
Container(quota, "quota-service", "NestJS + Temporal.io + CB", "Cuotas 15GB/50GB, saga de pago QR Simple, Circuit Breaker")
Container(notif, "notification-service", "NestJS + web-push", "Emails institucionales, push browser, Dead Letter Queue")
Container(admin_svc, "admin-service", "NestJS + CQRS Read Model", "Panel admin, métricas globales, audit log exportable PDF")

ContainerDb(pg, "PostgreSQL 16", "on-premise (primary + hot-standby)", "Usuarios, archivos, buzones, cuotas, audit_log")
ContainerDb(redis, "Redis Cluster 7", "on-premise (3 nodos, Consistent Hashing)", "Sesiones upload chunked; cache quota-service CB")
ContainerDb(s3_obj, "MinIO Object Storage", "on-premise + Object Lock WORM", "Archivos binarios; WORM post-cierre SimonDrop")
ContainerDb(rabbit, "RabbitMQ + DLQ", "on-premise", "Cola FileUploaded, QuotaUpgraded; Dead Letter Queue")

Rel(usuario, spa, "Accede", "HTTPS")
Rel(spa, gateway, "API Calls", "HTTPS REST")
Rel(gateway, auth, "Valida JWT", "gRPC")
Rel(gateway, files, "/files/*", "REST")
Rel(gateway, drops, "/drops/*", "REST")
Rel(gateway, quota, "/quota/*", "REST")
Rel(gateway, admin_svc, "/admin/*", "REST")
Rel(files, pg, "CRUD archivos", "SQL")
Rel(files, redis, "Sesiones upload", "Redis Protocol")
Rel(files, s3_obj, "PUT/GET objetos", "S3 API (MinIO)")
Rel(files, rabbit, "Publica FileUploadedEvent (Outbox)", "AMQP")
Rel(notif, rabbit, "Consume mensajes", "AMQP")
Rel(admin_svc, pg, "Read Model CQRS", "SQL (Replica)")
