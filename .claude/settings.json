{
  "permissions": {
    "allow": [
      "Bash(grep -E \"\\\\.\\(md|mmd\\)$\")",
      "Bash(git checkout *)",
      "Bash(git commit -m ' *)",
      "Bash(git mv *)",
      "Bash(git restore *)",
      "Bash(git stash *)",
      "Bash(git check-ignore *)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npx prisma *)",
      "Bash(npx tsc *)",
      "Bash(git tag *)",
      "Skill(update-config)",
      "Skill(update-config:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'commit' && RELOCATE_RESTAGE=1 python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/relocate-local-perms.py\" || true",
            "timeout": 10,
            "statusMessage": "Revisando settings.json antes del commit…"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'commit' && git -C \"$CLAUDE_PROJECT_DIR\" diff --cached --name-only | grep -q '^docs/baseline/' && { echo 'BLOQUEADO: docs/baseline/ es inmutable (tag release/2.0.0). Mueve el cambio a docs/product/.' >&2; exit 2; } || true",
            "timeout": 10,
            "statusMessage": "Verificando baseline congelado…"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/relocate-local-perms.py\"",
            "timeout": 10,
            "statusMessage": "Reubicando permisos locales…"
          }
        ]
      }
    ]
  }
}
